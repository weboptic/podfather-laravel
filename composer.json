{
    "name": "weboptic/podfather-laravel",
    "description": "A Laravel wrapper for the Podfather API",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Podfather\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Podfather\\PodfatherServiceProvider"
            ],
            "aliases": {
                "Podfather": "Podfather\\Facades\\Podfather"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
